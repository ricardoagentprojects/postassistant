# PostAssistant Backend Environment Variables
# Copy to .env and fill with your values

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/postassistant
# For production: Get from Railway/Supabase/Render

# JWT Secret (generate with: openssl rand -hex 32)
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60

# OpenAI API (for AI features)
OPENAI_API_KEY=sk-your-openai-api-key-here

# Email Service (SendGrid, etc.)
SENDGRID_API_KEY=your-sendgrid-api-key
FROM_EMAIL=noreply@postassistant.pt

# Environment
ENVIRONMENT=development  # development, production
DEBUG=true

# CORS Origins (comma separated)
CORS_ORIGINS=http://localhost:3000,https://postassistant.vercel.app

# Render/Railway will set PORT automatically
# PORT=8000