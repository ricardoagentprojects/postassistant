# PostAssistant Backend Environment Variables
# Copy to .env and fill with your values

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/postassistant
# For production: Get from Railway/Supabase/Render

# JWT Secret (generate with: openssl rand -hex 32)
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60

# OpenAI API (for AI features)
OPENAI_API_KEY=sk-your-openai-api-key-here

# Email Service (SendGrid, etc.)
SENDGRID_API_KEY=your-sendgrid-api-key
FROM_EMAIL=noreply@postassistant.pt

# Environment
ENVIRONMENT=development  # development, production
DEBUG=true

# CORS Origins (comma separated). Include http://127.0.0.1:3000 if you open the app that way.
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,https://postassistant.vercel.app

# Base URL of the Next.js app (password reset links in emails)
FRONTEND_URL=http://localhost:3000

# Render/Railway will set PORT automatically
# PORT=8000

# Quotas (UTC month) — AI generations that create a saved post
FREE_TIER_MONTHLY_GENERATIONS=25
PRO_TIER_MONTHLY_GENERATIONS=500
# Burst protection per user (per minute) for /generate, /variations, /refine
AI_CALLS_PER_USER_PER_MINUTE=20

# Stripe (optional — checkout returns 503 until configured)
# STRIPE_SECRET_KEY=sk_live_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# STRIPE_PRICE_ID_PRO=price_...

# After adding columns to users (Postgres example):
# ALTER TABLE users ADD COLUMN IF NOT EXISTS stripe_customer_id VARCHAR(255);
# ALTER TABLE users ADD COLUMN IF NOT EXISTS stripe_subscription_id VARCHAR(255);