# Copy to .env.local if needed.
# Em `next dev`, por omissão as chamadas vão a /api/v1 no mesmo host (proxy → FastAPI).
# Só define NEXT_PUBLIC_API_URL se a API estiver noutro domínio (ex.: produção):
# NEXT_PUBLIC_API_URL=https://api.example.com
#
# Docker: API_INTERNAL_URL=http://backend:8000 (já no docker-compose).
